SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
PORT=3000

# OS App Origin (for Fastify API CORS)
OS_APP_ORIGIN=http://localhost:5173

# Vite API URL (for OS React SPA connection)
VITE_API_URL=http://localhost:3000

# ---- P1 core services ----
# Postgres connection (Supabase → Project Settings → Database → connection string)
DATABASE_URL=postgres://user:pass@host:5432/postgres

# Operator identity: sole operator email + Supabase Auth JWT secret (HS256)
OPERATOR_EMAIL=mobiledynamic876@gmail.com
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Model router (@atlas/router) — OpenRouter-compatible endpoint
ATLAS_MODEL_BASE_URL=https://openrouter.ai/api
ATLAS_MODEL_API_KEY=your-openrouter-key
# Ordered fallback chains per task class (comma-separated model ids)
ATLAS_CHAIN_THINK=anthropic/claude-sonnet-4.5
ATLAS_CHAIN_DO=deepseek/deepseek-chat-v3-0324:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen-2.5-72b-instruct:free
ATLAS_CHAIN_QUICK=meta-llama/llama-3.2-3b-instruct:free,qwen/qwen-2.5-7b-instruct:free
ATLAS_MODEL_TIMEOUT_MS=45000
